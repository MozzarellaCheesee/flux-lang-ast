{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Flux",
  "scopeName": "source.flux",
  "fileTypes": ["flx"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#function-definition" },
    { "include": "#return-statement" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#function-call" },
    { "include": "#type-name" },
    { "include": "#self" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.block.flux",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.flux" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.comment.flux" } }
        },
        {
          "name": "comment.line.double-slash.flux",
          "match": "//.*$"
        }
      ]
    },

    "": {},

    "preprocessor": {
      "name": "meta.preprocessor.flux",
      "match": "(#import)\\s*(\"[^\"]*\")?",
      "captures": {
        "1": { "name": "keyword.control.import.flux" },
        "2": { "name": "string.quoted.double.flux" }
      }
    },

    "strings": {
      "name": "string.quoted.double.flux",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.flux" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.flux" } },
      "patterns": [
        {
          "name": "constant.character.escape.flux",
          "match": "\\\\."
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.flux",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.flux",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "constants": {
      "name": "constant.language.flux",
      "match": "\\b(true|false)\\b"
    },

    "keywords": {
      "patterns": [
        {
          "comment": "Управляющие конструкции",
          "name": "keyword.control.flux",
          "match": "\\b(if|else|for|while|return|break|continue|match)\\b"
        },
        {
          "comment": "Объявления",
          "name": "keyword.declaration.flux",
          "match": "\\b(fnc|let|struct|class|impl|pub)\\b"
        }
      ]
    },

    "types": {
      "name": "storage.type.flux",
      "match": "\\b(bool|int8|int16|int32|int64|int128|uint8|uint16|uint32|uint64|uint128|float|double|isize_t|usize_t|str|string)\\b"
    },

    "self": {
      "name": "variable.language.self.flux",
      "match": "\\bself\\b"
    },

    "function-definition": {
      "comment": "pub fnc name(...) или fnc name(...) — подсвечивает pub, fnc и имя функции",
      "patterns": [
        {
          "match": "\\b(pub)\\s+(fnc)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.declaration.flux" },
            "2": { "name": "keyword.declaration.flux" },
            "3": { "name": "entity.name.function.flux" }
          }
        },
        {
          "match": "\\b(fnc)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.declaration.flux" },
            "2": { "name": "entity.name.function.flux" }
          }
        }
      ]
    },

    "return-statement": {
      "comment": "return <value> — подсвечивает возвращаемый объект",
      "patterns": [
        {
          "comment": "return self",
          "match": "\\b(return)\\s+(self)\\b",
          "captures": {
            "1": { "name": "keyword.control.flux" },
            "2": { "name": "variable.language.self.flux" }
          }
        },
        {
          "comment": "return TypeName — тип/структура начинаются с заглавной",
          "match": "\\b(return)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.flux" },
            "2": { "name": "entity.name.type.flux" }
          }
        },
        {
          "comment": "return variable — обычная переменная",
          "match": "\\b(return)\\s+([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.flux" },
            "2": { "name": "variable.other.flux" }
          }
        }
      ]
    },

    "function-call": {
      "comment": "name(...) — вызов функции / метода",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.flux" }
      }
    },

    "type-name": {
      "comment": "Пользовательские типы — идентификаторы начинающиеся с заглавной буквы",
      "name": "entity.name.type.flux",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.flux",
          "match": "(->|=>)"
        },
        {
          "name": "keyword.operator.path.flux",
          "match": "::"
        },
        {
          "name": "keyword.operator.comparison.flux",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.flux",
          "match": "(\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.increment.flux",
          "match": "(\\+\\+|--)"
        },
        {
          "name": "keyword.operator.logical.flux",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.flux",
          "match": "(\\||\\^|<<|>>|~)"
        },
        {
          "name": "keyword.operator.reference.flux",
          "match": "&"
        },
        {
          "name": "keyword.operator.arithmetic.flux",
          "match": "(\\+|-|\\*|/|%)"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.braces.flux",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.brackets.flux",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.section.parens.flux",
          "match": "[()]"
        },
        {
          "name": "punctuation.separator.comma.flux",
          "match": ","
        },
        {
          "name": "punctuation.terminator.semicolon.flux",
          "match": ";"
        },
        {
          "name": "punctuation.separator.colon.flux",
          "match": ":"
        },
        {
          "name": "punctuation.accessor.dot.flux",
          "match": "\\."
        }
      ]
    }
  }
}
